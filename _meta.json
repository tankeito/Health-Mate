{
    "name": "health-mate",
    "display_name": "Health-Mate",
    "type": "python/app",
    "version": "1.1.11",
    "description": "Personal Health Assistant - 专业健康报告生成插件。自动读取本地记忆，生成带数据可视化的 PDF 报告，并支持多端推送。",
    "author": "tankeito",
    "email": "tqd354@gmail.com",
    "license": "MIT",
    "homepage": "https://github.com/tankeito/Health-Mate",
    "repository": "https://github.com/tankeito/Health-Mate.git",
    "source": "https://github.com/tankeito/Health-Mate",
    "openclaw_version": ">=2024.1.0",
    "python_version": ">=3.8",
    "install": "pip install -r requirements.txt",
    "dependencies": [
        "reportlab>=4.0.0",
        "pillow>=10.0.0",
        "matplotlib>=3.0.0"
    ],
    "capabilities": [
        "file_read",
        "pdf_generation",
        "http_request"
    ],
    "env": {
        "MEMORY_DIR": "OpenClaw 记忆文件目录路径（必填，用于读取健康记录）",
        "TAVILY_API_KEY": "Tavily 搜索 API 密钥（可选）",
        "DINGTALK_WEBHOOK": "钉钉群机器人 Webhook 地址（可选）",
        "FEISHU_WEBHOOK": "飞书群机器人 Webhook 地址（可选）",
        "TELEGRAM_BOT_TOKEN": "Telegram Bot API Token（可选）",
        "TELEGRAM_CHAT_ID": "Telegram 接收者 Chat ID（可选）",
        "REPORT_WEB_DIR": "PDF 报表存放的本地 Web 目录（可选）",
        "REPORT_BASE_URL": "PDF 报告对外下载域名（可选）",
        "REPORT_TIME": "每日健康报告推送时间（可选，默认 22）",
        "WEEKLY_REPORT_TIME": "每周健康周报推送时间（可选，默认每周一 09:00）"
    },
    "commands": [
        {
            "trigger": "/health",
            "description": "生成今日健康报告",
            "usage": "/health [date]",
            "example": "/health 2026-03-15"
        }
    ],
    "triggers": [
        {
            "type": "cron",
            "schedule": "0 22 * * *",
            "action": "daily_report",
            "description": "每日晚间健康报告（22:00）"
        },
        {
            "type": "cron",
            "schedule": "0 9 * * 1",
            "action": "weekly_report",
            "description": "每周健康周报（默认周一 09:00）"
        }
    ],
    "features": [
        "多维度健康评分与风险预警",
        "Matplotlib 全景数据可视化图表",
        "SaaS 级扁平化排版 PDF 导出",
        "多通道自动化推送"
    ],
    "tags": ["health", "fitness", "diet", "report", "wellness", "openclaw"]
}
