# Health-Mate Plugin - Environment Configuration Example
# Copy this file to .env and fill in your real values

# ========== Cron Environment Variables (Required for scheduled tasks) ==========

# Node.js NVM directory
NVM_DIR="/root/.nvm"

# Node.js binary path (for openclaw CLI in Cron environment)
OPENCLAW_PATH="/root/.nvm/versions/node/v22.22.0/bin"

# ========== Required Configuration ==========

# OpenClaw Memory File Directory (required, must set to your health Markdown directory)
MEMORY_DIR="/absolute/path/to/health-memory"

# ========== Messaging Configuration (Optional) ==========

# DingTalk Robot Webhook
DINGTALK_WEBHOOK="https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN"

# Feishu Robot Webhook
FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK"

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_CHAT_ID"

# ========== AI Features Configuration (Optional) ==========

# Tavily Search API Key (for AI health recipe search)
TAVILY_API_KEY="YOUR_API_KEY"

# ========== PDF Report Configuration (Optional) ==========

# PDF Report Web Publish Directory
REPORT_WEB_DIR="/opt/1panel/www/sites/agent.btc354.com/index"

# PDF Report Public Access Domain
REPORT_BASE_URL="https://agent.btc354.com"

# ========== Log Configuration (Optional) ==========

# Log File Path (default: logs/health_report_pro.log)
# LOG_FILE="/root/.openclaw/logs/health_report_pro.log"
