# ========== 健康报告插件配置模板 ==========
# 复制此文件为 .env 并填写真实值
# 注意：.env 文件已加入 .gitignore，切勿上传！

# ========== 消息推送配置 ==========

# 钉钉机器人 Webhook
# 获取方式：钉钉群 → 群设置 → 智能群助手 → 添加机器人 → 自定义
DINGTALK_WEBHOOK="https://oapi.dingtalk.com/robot/send?access_token=YOUR_ACCESS_TOKEN"

# 飞书机器人 Webhook
# 获取方式：飞书群 → 群设置 → 群机器人 → 添加机器人 → 自定义
FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID"

# Telegram Bot 配置
# 获取方式：联系 @BotFather 创建机器人
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_CHAT_ID"

# ========== 健康报告配置 ==========

# 健康记录目录（OpenClaw memory 目录）
MEMORY_DIR="/path/to/your/memory"

# 日志文件路径
LOG_FILE="/var/log/health_report_pro.log"

# 公网交付目录（PDF 报告存放位置）
PUBLIC_DIR="/path/to/public/dir"
PUBLIC_URL="https://your-domain.com"

# ========== 喝水提醒配置（可选）==========

# 天气坐标（默认成都）
WEATHER_LAT="30.5728"
WEATHER_LON="104.0668"
WEATHER_CITY="成都"

# 饮水目标（ml）
WATER_TARGET="2000"
