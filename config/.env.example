# 健康报告插件 - 环境变量配置示例
# 复制此文件为 .env 并填写真实值

# ========== 必需配置 ==========

# OpenClaw 记忆文件目录（必填）
MEMORY_DIR="/root/.openclaw/workspace/memory"

# ========== 消息推送配置（可选）==========

# 钉钉机器人 Webhook
DINGTALK_WEBHOOK="https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN"

# 飞书机器人 Webhook
FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK"

# Telegram Bot 配置
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_CHAT_ID"

# ========== AI 功能配置（可选）==========

# Tavily Search API Key（用于 AI 搜索健康菜谱）
TAVILY_API_KEY="YOUR_API_KEY"

# ========== PDF 报告配置（可选）==========

# PDF 报告 Web 发布目录
REPORT_WEB_DIR="/opt/1panel/www/sites/agent.btc354.com/index"

# PDF 报告公开访问域名
REPORT_BASE_URL="https://agent.btc354.com"

# ========== 日志配置（可选）==========

# 日志文件路径（默认：logs/health_report_pro.log）
# LOG_FILE="/root/.openclaw/logs/health_report_pro.log"
